    {
        "id": "d5bff1735d4dea14",
        "type": "function",
        "z": "3b781ccbf12f8cad",
        "name": "Inputs Horarios",
        "func": "function extraerHora(valor) {\n    if (valor === null || valor === undefined || valor === '') return null;\n    var str = String(valor).trim();\n    \n    // Si ya viene como HH:MM\n    if (/^\\d{1,2}:\\d{2}$/.test(str)) {\n        var partes = str.split(':');\n        return partes[0].padStart(2, '0') + ':' + partes[1];\n    }\n    \n    // Si viene como milisegundos (lo que envía el dashboard time picker)\n    var num = Number(str);\n    if (!isNaN(num) && num >= 0) {\n        var totalSegundos = Math.floor(num / 1000);\n        var totalMinutos  = Math.floor(totalSegundos / 60);\n        var h = Math.floor(totalMinutos / 60) % 24;\n        var m = totalMinutos % 60;\n        node.warn(\"extraerHora | raw=\" + num + \" → \" + h + \":\" + m);\n        return h.toString().padStart(2, '0') + ':' + m.toString().padStart(2, '0');\n    }\n    return null;\n}\n\nif (msg.topic === 'hora_inicio') {\n    var h = extraerHora(msg.payload);\n    flow.set('hora_inicio', h);\n    node.warn(\"hora_inicio guardada: \" + h);\n}\nif (msg.topic === 'hora_fin') {\n    var hf = extraerHora(msg.payload);\n    flow.set('hora_fin', hf);\n    node.warn(\"hora_fin guardada: \" + hf);\n}\nif (msg.topic === 'duracion_valor') {\n    flow.set('duracion_valor', Number(msg.payload));\n}\nif (msg.topic === 'duracion_unidad') {\n    flow.set('duracion_unidad', msg.payload);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1000,
        "y": 280,
        "wires": [
            []
        ]
    },
    {
        "id": "1ea8626963be4fe4",
        "type": "function",
        "z": "3b781ccbf12f8cad",
        "name": "function guardar",
        "func": "var horaInicio = flow.get('hora_inicio');\nvar horaFin    = flow.get('hora_fin');\nvar durValor   = flow.get('duracion_valor');\nvar durUnidad  = flow.get('duracion_unidad');\n\nnode.warn(\"GUARDANDO | inicio=\" + horaInicio + \" | fin=\" + horaFin +\n          \" | valor=\" + durValor + \" | unidad=\" + durUnidad);\n\nif (!horaInicio || !horaFin || !durValor || !durUnidad) {\n    msg.payload = '⚠️ Completa todos los campos antes de guardar';\n    return msg;\n}\n\nvar mult = 1;\nif (durUnidad === 'Minutos') mult = 60;\nif (durUnidad === 'Horas')   mult = 3600;\n\nflow.set('duracion_fuga',   durValor * mult);\nflow.set('reset_deteccion', Date.now());\n\nmsg.payload = '✅ Guardado: ' + horaInicio + ' - ' + horaFin +\n              ' | Fuga tras: ' + durValor + ' ' + durUnidad;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
