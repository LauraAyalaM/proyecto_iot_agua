        "func": "// ─── CORRECCIÓN #4: Leer desde flow.get (unificado) ───\nvar horaInicio = flow.get('hora_inicio');\nvar horaFin    = flow.get('hora_fin');\nvar durValor   = flow.get('duracion_valor');\nvar durUnidad  = flow.get('duracion_unidad');\n\nif (!horaInicio || !horaFin || !durValor || !durUnidad) {\n    msg.payload = 'Sin configuración guardada. Ingresa los datos y presiona Guardar cambios.';\n} else {\n    msg.payload =\n        'Configuración activa:<br>' +\n        '* Horario de evaluación: ' + horaInicio + ' → ' + horaFin + '<br>' +\n        '* Tiempo para alerta de fuga: ' + durValor + ' ' + durUnidad;\n}\nreturn msg;",
