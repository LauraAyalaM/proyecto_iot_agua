    {
        "id": "d3704812ba7a0e8b",
        "type": "function",
        "z": "3b781ccbf12f8cad",
        "name": "función detección anomalia",
        "func": "var ultimoReset = flow.get('reset_deteccion') || 0;\nvar resetVisto = context.get('resetVisto') || 0;\n\nif (ultimoReset > resetVisto) {\n    context.set('resetVisto', ultimoReset);\n    context.set('inicioFlujo', null);\n    context.set('alertaEnviada', false);\n}\n\nvar flujo = Number(msg.payload.flujo);\nvar ahora = new Date();\n// Ajuste zona horaria Colombia UTC-5\nvar offsetColombia = -5 * 60; // minutos\nvar utcMinutos = ahora.getUTCHours() * 60 + ahora.getUTCMinutes();\nvar localMinutos = ((utcMinutos + offsetColombia) + 1440) % 1440;\nvar hora = Math.floor(localMinutos / 60);\nvar minuto = localMinutos % 60;\n\nvar horaInicioStr = flow.get('hora_inicio');\nvar horaFinStr = flow.get('hora_fin');\nvar duracionSegundos = flow.get('duracion_fuga');\nvar valor = flow.get('duracion_valor');\nvar unidad = flow.get('duracion_unidad');\n\n// ✅ DIAGNÓSTICO 1: ver qué llega\nnode.warn(\"VALORES | flujo=\" + flujo +\n    \" | horaInicio=\" + horaInicioStr +\n    \" | horaFin=\" + horaFinStr +\n    \" | durFuga=\" + duracionSegundos +\n    \" | valor=\" + valor +\n    \" | unidad=\" + unidad);\n\nif (!horaInicioStr || !horaFinStr) {\n    node.warn(\"SALIDA: falta hora inicio o fin\");\n    return null;\n}\nif (!duracionSegundos || !valor || !unidad) {\n    node.warn(\"SALIDA: falta duracion\");\n    return null;\n}\n\nvar DURACION_ANOMALIA_MS = duracionSegundos * 1000;\n\nvar hInicio = Number(horaInicioStr.split(':')[0]);\nvar mInicio = Number(horaInicioStr.split(':')[1]);\nvar hFin = Number(horaFinStr.split(':')[0]);\nvar mFin = Number(horaFinStr.split(':')[1]);\n\nvar minutosActual = hora * 60 + minuto;\nvar minutosInicio = hInicio * 60 + mInicio;\nvar minutosFin = hFin * 60 + mFin;\n\nvar esHorarioEvaluacion;\nif (minutosInicio < minutosFin) {\n    esHorarioEvaluacion = (minutosActual >= minutosInicio && minutosActual < minutosFin);\n} else {\n    esHorarioEvaluacion = (minutosActual >= minutosInicio || minutosActual < minutosFin);\n}\n\n// ✅ DIAGNÓSTICO 2: ver si la hora actual está dentro del rango\nnode.warn(\"HORARIO | actual=\" + hora + \":\" + minuto +\n    \" | minutosActual=\" + minutosActual +\n    \" | minutosInicio=\" + minutosInicio +\n    \" | minutosFin=\" + minutosFin +\n    \" | esHorario=\" + esHorarioEvaluacion);\n\nvar UMBRAL_MINIMO = 0.07;\n\nif (flujo >= UMBRAL_MINIMO && esHorarioEvaluacion) {\n    var inicio = context.get('inicioFlujo');\n    if (inicio === null || inicio === undefined) {\n        inicio = ahora.getTime();\n        context.set('inicioFlujo', inicio);\n    }\n\n    var duracionMs = ahora.getTime() - inicio;\n    node.warn(\"⏱ duracionMs=\" + duracionMs + \" | necesita=\" + DURACION_ANOMALIA_MS);\n\n    if (duracionMs >= DURACION_ANOMALIA_MS) {\n        var alertaEnviada = context.get('alertaEnviada') || false;\n        if (!alertaEnviada) {\n            context.set('alertaEnviada', true);\n            msg.to = \"laurasofiaayalamartinez@gmail.com\";\n            msg.topic = '⚠️ ALERTA: Posible anomalía de consumo de agua';\n            msg.payload =\n                '⚠️ ALERTA DE AGUA\\n\\n' +\n                'Flujo detectado: ' + flujo + ' L/min\\n' +\n                'Horario evaluado: ' + horaInicioStr + ' - ' + horaFinStr + '\\n' +\n                'Flujo activo por más de: ' + valor + ' ' + unidad + '\\n' +\n                'Posible fuga o llave abierta.\\n\\n' +\n                'Sistema IoT - Bucaramanga';\n            return msg;\n        }\n    }\n} else {\n    node.warn(\"SALIDA: flujo=\" + flujo + \" < umbral o fuera de horario. esHorario=\" + esHorarioEvaluacion);\n    context.set('inicioFlujo', null);\n    context.set('alertaEnviada', false);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
